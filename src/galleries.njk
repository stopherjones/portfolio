---
pagination:
  data: photos
  size: 1
  alias: gallery
permalink: "/{{ gallery.slug }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ gallery.name | capitalize }} | Photography Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Poiret+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ pathPrefix }}/assets/style.css">
  <link rel="stylesheet" href="{{ pathPrefix }}/assets/photoswipe/photoswipe.css">
</head>
<body>

    {% include "navbar.njk" %}

  <main>
    {% if gallery.intro %}
      <section class="gallery-intro">
        <h1>{{ gallery.intro.title }}</h1>
        {% for paragraph in gallery.intro.paragraphs %}
          <p>{{ paragraph }}</p>
        {% endfor %}
      </section>
    {% endif %}

  <div class="gallery" id="gallery-container">
  {% for image in gallery.images %}
    {# This prevents cover.jpg from appearing inside the gallery #}
    {% if "cover" not in image.path %}
      {% galleryImage image.path, image.title or "Photo from " + gallery.name %}
    {% endif %}
  {% endfor %}
</div>
</main>

<script type="module">
  import PhotoSwipeLightbox from '{{ pathPrefix }}/assets/photoswipe/photoswipe-lightbox.esm.js';
  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery-container',
    children: 'a', // This tells PhotoSwipe to navigate between all <a> tags found here 
    pswpModule: () => import('{{ pathPrefix }}/assets/photoswipe/photoswipe.esm.js')
  });
  lightbox.init(); // [cite: 5]
</script>

  {% include "footer.njk" %}

</body>
</html>