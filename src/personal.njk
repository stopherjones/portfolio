title: Personal Projects
permalink: "/personal-projects/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Poiret+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
    
    {% include "navbar.njk" %}

  <main>
  <div class="gallery-grid"> {# Use 'gallery-grid' here #}
    {% for gallery in photos %}
      {% if gallery.isPersonal %}
        <a href="/{{ gallery.slug }}/" class="gallery-card">
          <div class="card-image">
            {% if gallery.cover %}
              <img src="{{ gallery.cover }}" alt="{{ gallery.name }} Cover">
            {% else %}
              <div class="placeholder-bg" style="background: #333; height: 100%;"></div>
            {% endif %}
          </div>
          <div class="card-overlay">
            <h2>{{ gallery.name }}</h2>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</main>

  {% include "footer.njk" %}
  
</body>
</html>